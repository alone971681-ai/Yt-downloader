{
  "compilerOptions": {
    "isolatedModules": true,
    "lib": ["dom", "esnext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noImplicitAny": true,
    "strictNullChecks": true,
    "skipLibCheck": true,
    "target": "es2022",
    "jsx": "preserve"
  },
  "include": ["src"]
}
